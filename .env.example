# ──────────────────────────────────────────────────────────────────────────────
# PROSPERKT CRM — .env de HOMOLOGAÇÃO
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env real no git (já está no .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Porta que o servidor Node escutará (Railway/Render/Fly usam $PORT automaticamente)
PORT=3000

# Ambiente (mude para "production" em homologação/produção real)
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_1
JWT_REFRESH_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_2
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECRET=TROQUE_POR_STRING_ALEATORIA_LONGA_3

# ── Banco de dados ────────────────────────────────────────────────────────────
# Use "supabase" em homologação/produção
DATABASE_PROVIDER=supabase

# Caminho do SQLite (só usado se DATABASE_PROVIDER=sqlite)
DB_PATH=./data/prosperkt.db

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SUA_CHAVE_ANON_AQUI
SUPABASE_SERVICE_ROLE_KEY=sb_secret_SUA_CHAVE_SERVICE_ROLE_AQUI

# ── CORS (obrigatório em NODE_ENV=production) ─────────────────────────────────
# Informe a URL pública do CRM (sem barra no final)
CORS_ORIGIN=https://seu-crm-homologacao.railway.app

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────

# URL do servidor Evolution API (pode ser externo ou Docker)
# Em homologação, precisa ser acessível pelo CRM (não pode ser localhost do cliente)
EVOLUTION_API_URL=https://seu-servidor-evolution.com

# Chave de API do Evolution Manager (aba Authentication > API Key no painel)
EVOLUTION_API_KEY=sua-chave-evolution-aqui

# Nome da instância WhatsApp (deve bater com o criado no Evolution Manager)
# Aceita EVOLUTION_INSTANCE_NAME (preferido) ou EVOLUTION_INSTANCE (legado)
EVOLUTION_INSTANCE_NAME=prosperkt_homolog

# ── Webhook WhatsApp ──────────────────────────────────────────────────────────

# URL pública completa do endpoint de webhook do CRM.
# A Evolution API usará este endereço para POSTar eventos de mensagens.
# Endpoint: POST /api/whatsapp/webhook
# Exemplo: https://seu-crm-homologacao.railway.app/api/whatsapp/webhook
WEBHOOK_URL=https://seu-crm-homologacao.railway.app/api/whatsapp/webhook

# Secret opcional para validar chamadas do webhook (mesmo valor no Evolution Manager)
# Se não configurado, o CRM aceita qualquer POST no endpoint (menos seguro)
WHATSAPP_WEBHOOK_SECRET=seu-secret-aqui
